# EntraClaw — local environment configuration template
#
# Copy this file to .env and fill in your values, OR run scripts/setup.sh
# which generates .env automatically from your Entra provisioning output.
#
# .env is gitignored — never commit it.
# Private keys are stored in the OS credential store (Keychain/TPM/Keyring),
# not here.

# ── Entra tenant ─────────────────────────────────────────────────────────────
ENTRACLAW_TENANT_ID=<your-tenant-id>

# ── Agent Identity Blueprint (the "template" app registration) ───────────────
ENTRACLAW_BLUEPRINT_APP_ID=<blueprint-app-id>
ENTRACLAW_BLUEPRINT_OBJECT_ID=<blueprint-object-id>
ENTRACLAW_BLUEPRINT_CERT_THUMBPRINT=<cert-thumbprint-hex>

# ── Agent Identity (the per-instance service principal) ─────────────────────
ENTRACLAW_AGENT_ID=<agent-app-id>
ENTRACLAW_AGENT_OBJECT_ID=<agent-object-id>

# ── Agent User (the Teams/Outlook identity, idtyp=user) ─────────────────────
ENTRACLAW_AGENT_USER_ID=<agent-user-object-id>
ENTRACLAW_AGENT_USER_UPN=<entraclaw-agent@yourtenant.onmicrosoft.com>

# ── Human sponsor (who the agent can DM / is accountable to) ────────────────
ENTRACLAW_HUMAN_USER_ID=<your-entra-object-id>
ENTRACLAW_HUMAN_UPN=<you@yourtenant.onmicrosoft.com>

# ── Multi-sponsor support (comma-separated lists, same order) ────────────────
ENTRACLAW_HUMAN_USER_IDS=<id1,id2>
ENTRACLAW_HUMAN_UPNS=<upn1@example.com,upn2@example.com>
ENTRACLAW_HUMAN_USER_TENANT_IDS=<tenant-id-1,tenant-id-2>
ENTRACLAW_HUMAN_USER_MAILS=<mail1@example.com,mail2@example.com>
ENTRACLAW_HUMAN_USER_TYPES=<internal,b2b>

# ── Provisioner app (used only during setup, not at runtime) ─────────────────
ENTRACLAW_PROVISIONER_APP_ID=<provisioner-app-id>

# ── Logging ──────────────────────────────────────────────────────────────────
ENTRACLAW_LOG_LEVEL=INFO

# ── ADR-005: Azure Blob Storage for agent operational memory (optional) ───────
# Leave blank to use local storage (default).
ENTRACLAW_BLOB_ENDPOINT=
ENTRACLAW_BLOB_CONTAINER=
