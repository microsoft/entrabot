# EntraBot — local environment configuration template
#
# Copy this file to .env and fill in your values, OR run scripts/setup.sh
# which generates .env automatically from your Entra provisioning output.
#
# .env is gitignored — never commit it.
# Private keys are stored in the OS credential store (Keychain/TPM/Keyring),
# not here.

# ── Entra tenant ─────────────────────────────────────────────────────────────
ENTRABOT_TENANT_ID=<your-tenant-id>

# ── Agent Identity Blueprint (the "template" app registration) ───────────────
ENTRABOT_BLUEPRINT_APP_ID=<blueprint-app-id>
ENTRABOT_BLUEPRINT_OBJECT_ID=<blueprint-object-id>
ENTRABOT_BLUEPRINT_CERT_THUMBPRINT=<cert-thumbprint-hex>

# ── Agent Identity (the per-instance service principal) ─────────────────────
ENTRABOT_AGENT_ID=<agent-app-id>
ENTRABOT_AGENT_OBJECT_ID=<agent-object-id>

# ── Agent User (the Teams/Outlook identity, idtyp=user) ─────────────────────
ENTRABOT_AGENT_USER_ID=<agent-user-object-id>
# Canonical machine identity — used by the self-authored Teams-poll filter to
# recognize the agent's own outbound messages (Learning #69). Match on UPN
# first, AAD object-id fallback; NEVER on displayName (mutable + localizable).
# Accepts either ENTRABOT_AGENT_UPN (canonical) or the legacy
# ENTRABOT_AGENT_USER_UPN alias.
ENTRABOT_AGENT_UPN=<entrabot-agent@yourtenant.onmicrosoft.com>
ENTRABOT_AGENT_USER_UPN=<entrabot-agent@yourtenant.onmicrosoft.com>

# ── Human sponsor (who the agent can DM / is accountable to) ────────────────
ENTRABOT_HUMAN_USER_ID=<your-entra-object-id>
ENTRABOT_HUMAN_UPN=<you@yourtenant.onmicrosoft.com>

# ── Multi-sponsor support (comma-separated lists, same order) ────────────────
ENTRABOT_HUMAN_USER_IDS=<id1,id2>
ENTRABOT_HUMAN_UPNS=<upn1@example.com,upn2@example.com>
ENTRABOT_HUMAN_USER_TENANT_IDS=<tenant-id-1,tenant-id-2>
ENTRABOT_HUMAN_USER_MAILS=<mail1@example.com,mail2@example.com>
ENTRABOT_HUMAN_USER_TYPES=<internal,b2b>

# ── Provisioner app (used only during setup, not at runtime) ─────────────────
ENTRABOT_PROVISIONER_APP_ID=<provisioner-app-id>

# ── Logging ──────────────────────────────────────────────────────────────────
ENTRABOT_LOG_LEVEL=INFO

# ── ADR-005: Azure Blob Storage for agent operational memory (optional) ───────
# Leave blank to use local storage (default).
ENTRABOT_BLOB_ENDPOINT=
ENTRABOT_BLOB_CONTAINER=
