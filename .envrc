# direnv auto-activation for this repo.
#
# Setup (one-time, per dev machine):
#   brew install direnv
#   eval "$(direnv hook zsh)"   # or: eval "$(direnv hook bash)"
#   direnv allow
#
# With direnv allowed, bare `python3` in any shell or tool call under
# this directory resolves to .venv/bin/python3 — so the body anatomy's
# "Python tool-call hygiene" rule is mostly satisfied automatically.

export CLAUDE_PROJECT_DIR="$PWD"

if [ -f .venv/bin/activate ]; then
    # shellcheck disable=SC1091
    source .venv/bin/activate
else
    echo "⚠️  .venv not found. Run: python3 -m venv .venv && source .venv/bin/activate && pip install -e '.[dev]'" >&2
fi

